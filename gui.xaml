<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyWinKit" Height="650" Width="900"
        Background="#1E1E1E" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0E639C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="15,10">
            <TextBlock Text="MyWinKit  -  All-in-One Windows Toolkit"
                       Foreground="#4FC3F7" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="#1E1E1E" BorderThickness="0">

            <!-- Tab: Install Apps -->
            <TabItem Header="Install Apps">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="AppsPanel" Margin="15"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,10">
                        <Button x:Name="InstallBtn" Content="Install Selected" Margin="0,0,10,0"/>
                        <Button x:Name="UninstallBtn" Content="Uninstall Selected" Background="#C42B1C"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab: Tweaks -->
            <TabItem Header="Tweaks &amp; Debloat">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TweaksPanel" Margin="15"/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,10">
                        <Button x:Name="ApplyTweaksBtn" Content="Apply Selected Tweaks"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Tab: Custom Scripts -->
            <TabItem Header="My Scripts">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="CustomPanel" Margin="15"/>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Log Output -->
        <Border Grid.Row="2" Background="#0C0C0C" Margin="10,5,10,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="LogBox" Background="Transparent" Foreground="#7FFF7F"
                         FontFamily="Consolas" FontSize="12" BorderThickness="0"
                         IsReadOnly="True" TextWrapping="Wrap" Padding="10"
                         Text="Ready. Select options and click an action button.&#x0a;"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
